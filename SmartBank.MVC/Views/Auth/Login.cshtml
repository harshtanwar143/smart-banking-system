@model SmartBank.Models.DTOs.Auth.LoginRequestDto
@{
    ViewData["Title"] = "Sign in";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-brand">
            <div class="auth-brand-mark"><i class="bi bi-bank2"></i></div>
            <h1 class="auth-title">Welcome back</h1>
            <p class="auth-subtitle">Sign in to your SmartBank account</p>
        </div>

        <form asp-action="Login" asp-controller="Auth" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="alert alert-danger py-2 small mb-3" role="alert">
                    <i class="bi bi-exclamation-circle me-1"></i>
                    <span asp-validation-summary="All"></span>
                </div>
            }

            <div class="mb-3">
                <label asp-for="Email" class="form-label-pro">Email address</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="bi bi-envelope text-muted"></i></span>
                    <input asp-for="Email" type="email" class="form-control auth-input border-start-0"
                           placeholder="you@example.com" required autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="mb-3">
                <div class="d-flex justify-content-between mb-1">
                    <label asp-for="Password" class="form-label-pro mb-0">Password</label>
                    <a href="#" class="text-decoration-none small text-muted">Forgot password?</a>
                </div>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="bi bi-lock text-muted"></i></span>
                    <input asp-for="Password" type="password" class="form-control auth-input border-start-0 border-end-0"
                           id="passwordInput" placeholder="Your password" required autocomplete="current-password" />
                    <button type="button" class="input-group-text bg-light border-start-0" id="passwordToggle" tabindex="-1">
                        <i class="bi bi-eye text-muted" id="toggleIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="rememberMe">
                <label class="form-check-label small text-muted" for="rememberMe">Keep me signed in</label>
            </div>

            <button type="submit" class="auth-btn">
                <i class="bi bi-shield-lock me-2"></i>Sign in securely
            </button>
        </form>

        <p class="auth-footer">
            New to SmartBank?
            <a asp-controller="Auth" asp-action="Register">Create an account</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function() {
            var toggle = document.getElementById('passwordToggle');
            var input  = document.getElementById('passwordInput');
            var icon   = document.getElementById('toggleIcon');
            if (toggle) {
                toggle.addEventListener('click', function() {
                    var isPwd = input.type === 'password';
                    input.type = isPwd ? 'text' : 'password';
                    icon.classList.toggle('bi-eye');
                    icon.classList.toggle('bi-eye-slash');
                });
            }
        })();
    </script>
}
