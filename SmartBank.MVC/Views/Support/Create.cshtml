@model SmartBank.Models.DTOs.Support.CreateTicketDto
@{
    ViewData["Title"] = "Raise Ticket";
}

<div class="page-header">
    <h1>Raise a support ticket</h1>
    <p>Tell us what is wrong. We will get back to you within 24 hours.</p>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card-pro">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                @if (ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert alert-danger small">
                        <span asp-validation-summary="All"></span>
                    </div>
                }

                <div class="row g-3">
                    <div class="col-md-8">
                        <label asp-for="Subject" class="form-label-pro">Subject</label>
                        <input asp-for="Subject" class="form-control form-control-pro"
                               placeholder="Briefly describe the issue" maxlength="200" />
                        <span asp-validation-for="Subject" class="field-validation-error"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Priority" class="form-label-pro">Priority</label>
                        <select asp-for="Priority" class="form-select form-control-pro">
                            <option value="Low">Low</option>
                            <option value="Medium">Medium</option>
                            <option value="High">High</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Category" class="form-label-pro">Category</label>
                        <select asp-for="Category" class="form-select form-control-pro">
                            <option>Account</option>
                            <option>Transaction</option>
                            <option>Loan</option>
                            <option>Card</option>
                            <option>Login</option>
                            <option>Other</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label-pro">Description</label>
                        <textarea asp-for="Description" class="form-control form-control-pro" rows="6"
                                  placeholder="Provide details: what happened, when, and any reference numbers"
                                  maxlength="2000"></textarea>
                        <span asp-validation-for="Description" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary-pro">
                        <i class="bi bi-send me-1"></i>Submit ticket
                    </button>
                    <a asp-action="Index" class="btn btn-outline-pro">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
