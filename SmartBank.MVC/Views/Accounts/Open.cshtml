@model SmartBank.Models.DTOs.Accounts.CreateAccountDto
@{
    ViewData["Title"] = "Open Account";
}

<div class="page-header">
    <h1>Open a new account</h1>
    <p>Choose your account type and make an initial deposit. Minimum INR 500.</p>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card-pro">
            <form asp-action="Open" method="post">
                @Html.AntiForgeryToken()

                @if (ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert alert-danger small">
                        <span asp-validation-summary="All"></span>
                    </div>
                }

                <div class="mb-4">
                    <label class="form-label-pro">Choose account type</label>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <input type="radio" class="btn-check" name="AccountType" id="typeSavings" value="Savings" checked>
                            <label class="card-pro w-100 cursor-pointer text-center pt-3 pb-3" for="typeSavings"
                                   style="cursor: pointer;">
                                <div class="stat-icon-bubble bg-success-soft mx-auto mb-2"><i class="bi bi-piggy-bank"></i></div>
                                <h6 class="fw-bold mb-1">Savings Account</h6>
                                <small class="text-muted">Earn interest on your savings. Min balance INR 500.</small>
                            </label>
                        </div>
                        <div class="col-md-6">
                            <input type="radio" class="btn-check" name="AccountType" id="typeCurrent" value="Current">
                            <label class="card-pro w-100 cursor-pointer text-center pt-3 pb-3" for="typeCurrent"
                                   style="cursor: pointer;">
                                <div class="stat-icon-bubble bg-warning-soft mx-auto mb-2"><i class="bi bi-cash-stack"></i></div>
                                <h6 class="fw-bold mb-1">Current Account</h6>
                                <small class="text-muted">For business and frequent transactions.</small>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="InitialDeposit" class="form-label-pro">Initial deposit (INR)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light">INR</span>
                        <input asp-for="InitialDeposit" class="form-control form-control-pro"
                               type="number" step="0.01" min="500" placeholder="500" />
                    </div>
                    <div class="form-help">Minimum INR 500. This will be your account opening balance.</div>
                    <span asp-validation-for="InitialDeposit" class="field-validation-error"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary-pro">
                        <i class="bi bi-check-lg me-1"></i>Open account
                    </button>
                    <a asp-action="Index" class="btn btn-outline-pro">Cancel</a>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card-pro">
            <h6 class="fw-bold"><i class="bi bi-info-circle me-1 text-primary"></i>What to know</h6>
            <ul class="small text-muted ps-3 mb-0">
                <li class="mb-2">Account number is generated instantly.</li>
                <li class="mb-2">Initial deposit is fully credited to your balance.</li>
                <li class="mb-2">Savings accounts maintain a minimum balance of INR 500.</li>
                <li class="mb-2">No paperwork. No hidden fees.</li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
