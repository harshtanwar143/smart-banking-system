@model SmartBank.Models.DTOs.Loans.LoanListDto
@{
    ViewData["Title"] = "Manage Loans";
    var pending  = Model.Loans.Where(l => l.Status == "Pending").ToList();
    var reviewed = Model.Loans.Where(l => l.Status != "Pending").ToList();
}

<div class="page-header">
    <h1>Manage loans</h1>
    <p>Review, approve or reject loan applications.</p>
</div>

<!-- Pending loans -->
<div class="card-pro mb-4">
    <h6 class="fw-bold mb-3">
        <i class="bi bi-hourglass-split text-warning me-1"></i>
        Pending review (@pending.Count)
    </h6>

    @if (pending.Count == 0)
    {
        <div class="empty-state py-3">
            <i class="bi bi-check-circle"></i>
            <p class="mb-0">No loans pending review. All caught up.</p>
        </div>
    }
    else
    {
        @foreach (var l in pending)
        {
            <div class="border rounded p-3 mb-3 bg-light">
                <div class="row align-items-center">
                    <div class="col-md-5">
                        <div class="fw-bold">Loan #@l.LoanId - @l.LoanType</div>
                        <div class="text-muted small">
                            Applied on @l.CreatedAt.ToString("dd MMM yyyy")
                        </div>
                        <div class="small mt-1">
                            <strong>Amount:</strong> INR @l.RequestedAmount.ToString("N2") |
                            <strong>Tenure:</strong> @l.TenureMonths months
                        </div>
                        <div class="small text-muted mt-1"><strong>Purpose:</strong> @l.Purpose</div>
                    </div>
                    <div class="col-md-7">
                        <form asp-action="ReviewLoan" method="post" class="row g-2 align-items-end">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="LoanId" value="@l.LoanId" />

                            <div class="col-sm-4">
                                <label class="form-label-pro small">Approved amount</label>
                                <input type="number" name="ApprovedAmount" class="form-control form-control-sm"
                                       value="@l.RequestedAmount" step="1000" min="10000" />
                            </div>
                            <div class="col-sm-3">
                                <label class="form-label-pro small">Rate (% p.a.)</label>
                                <input type="number" name="InterestRate" class="form-control form-control-sm"
                                       value="10.5" step="0.1" min="0" max="50" />
                            </div>
                            <div class="col-sm-5">
                                <label class="form-label-pro small">Rejection reason</label>
                                <input type="text" name="RejectionReason" class="form-control form-control-sm"
                                       placeholder="Only if rejecting" maxlength="500" />
                            </div>
                            <div class="col-12 d-flex gap-2 mt-2">
                                <button type="submit" name="Approve" value="true"
                                        class="btn btn-sm btn-success">
                                    <i class="bi bi-check-lg me-1"></i>Approve
                                </button>
                                <button type="submit" name="Approve" value="false"
                                        class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-x-lg me-1"></i>Reject
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Reviewed loans history -->
<div class="card-pro p-0">
    <div class="px-3 pt-3">
        <h6 class="fw-bold mb-0">Reviewed loans (@reviewed.Count)</h6>
    </div>

    @if (reviewed.Count == 0)
    {
        <div class="empty-state py-3">
            <p class="mb-0">No reviewed loans yet.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table-pro">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Type</th>
                        <th>Requested</th>
                        <th>Approved</th>
                        <th>Rate</th>
                        <th>EMI</th>
                        <th>Status</th>
                        <th>Reviewed</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var l in reviewed)
                    {
                        var badge = l.Status == "Approved" ? "success" : "danger";
                        <tr>
                            <td class="fw-semibold">#@l.LoanId</td>
                            <td>@l.LoanType</td>
                            <td>INR @l.RequestedAmount.ToString("N2")</td>
                            <td>@(l.ApprovedAmount.HasValue ? $"INR {l.ApprovedAmount:N2}" : "-")</td>
                            <td>@(l.InterestRate.HasValue ? $"{l.InterestRate}%" : "-")</td>
                            <td>@(l.EmiAmount.HasValue ? $"INR {l.EmiAmount:N2}" : "-")</td>
                            <td><span class="badge-pro @badge">@l.Status</span></td>
                            <td class="text-muted small">
                                @(l.ReviewedAt?.ToString("dd MMM yyyy") ?? "-")
                                @if (!string.IsNullOrEmpty(l.ReviewedBy))
                                {
                                    <br /><small>by @l.ReviewedBy</small>
                                }
                            </td>
                        </tr>
                        @if (l.Status == "Rejected" && !string.IsNullOrEmpty(l.RejectionReason))
                        {
                            <tr>
                                <td colspan="8" class="bg-light small text-danger">
                                    <i class="bi bi-info-circle me-1"></i>@l.RejectionReason
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>
