@model SmartBank.Models.DTOs.Transactions.WithdrawRequestDto
@{
    ViewData["Title"] = "Withdraw";
    var accounts = ViewBag.Accounts as List<SmartBank.Models.DTOs.Accounts.AccountResponseDto>
                   ?? new List<SmartBank.Models.DTOs.Accounts.AccountResponseDto>();
}

<div class="page-header">
    <h1>Withdraw funds</h1>
    <p>Withdraw money from your SmartBank account.</p>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card-pro">
            @if (accounts.Count == 0)
            {
                <div class="empty-state">
                    <i class="bi bi-wallet2"></i>
                    <h6>No accounts yet</h6>
                    <p>You need an account before you can withdraw.</p>
                    <a asp-controller="Accounts" asp-action="Open" class="btn btn-primary-pro mt-2">Open an account</a>
                </div>
            }
            else
            {
                <form asp-action="Withdraw" method="post">
                    @Html.AntiForgeryToken()

                    @if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="alert alert-danger small">
                            <span asp-validation-summary="All"></span>
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="AccountId" class="form-label-pro">Withdraw from account</label>
                        <select asp-for="AccountId" class="form-select form-control-pro">
                            <option value="">-- Select account --</option>
                            @foreach (var a in accounts.Where(x => x.Status == "Active"))
                            {
                                <option value="@a.AccountId">
                                    @a.AccountType - @a.AccountNumber (Balance: INR @a.Balance.ToString("N2"))
                                </option>
                            }
                        </select>
                        <span asp-validation-for="AccountId" class="field-validation-error"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Amount" class="form-label-pro">Amount (INR)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">INR</span>
                            <input asp-for="Amount" type="number" step="0.01" min="1"
                                   class="form-control form-control-pro" placeholder="500.00" />
                        </div>
                        <div class="form-help">A minimum balance of INR 500 will be maintained on savings accounts.</div>
                        <span asp-validation-for="Amount" class="field-validation-error"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label-pro">Description (optional)</label>
                        <input asp-for="Description" class="form-control form-control-pro"
                               placeholder="e.g. Cash withdrawal" maxlength="500" />
                    </div>

                    <button type="submit" class="btn btn-primary-pro">
                        <i class="bi bi-arrow-down-circle me-1"></i>Withdraw
                    </button>
                    <a asp-controller="Accounts" asp-action="Index" class="btn btn-outline-pro">Cancel</a>
                </form>
            }
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card-pro">
            <h6 class="fw-bold"><i class="bi bi-shield-check me-1 text-warning"></i>Withdrawal rules</h6>
            <ul class="small text-muted ps-3 mb-0">
                <li class="mb-2">Cannot exceed available balance minus minimum balance.</li>
                <li class="mb-2">All withdrawals are recorded for audit.</li>
                <li class="mb-2">Cannot withdraw from frozen accounts.</li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
