@model SmartBank.Models.DTOs.Transactions.DepositRequestDto
@{
    ViewData["Title"] = "Deposit";
    var accounts = ViewBag.Accounts as List<SmartBank.Models.DTOs.Accounts.AccountResponseDto>
                   ?? new List<SmartBank.Models.DTOs.Accounts.AccountResponseDto>();
}

<div class="page-header">
    <h1>Deposit funds</h1>
    <p>Add money to your SmartBank account.</p>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card-pro">
            @if (accounts.Count == 0)
            {
                <div class="empty-state">
                    <i class="bi bi-wallet2"></i>
                    <h6>No accounts yet</h6>
                    <p>You need at least one account to make a deposit.</p>
                    <a asp-controller="Accounts" asp-action="Open" class="btn btn-primary-pro mt-2">
                        <i class="bi bi-plus-lg me-1"></i>Open an account
                    </a>
                </div>
            }
            else
            {
                <form asp-action="Deposit" method="post">
                    @Html.AntiForgeryToken()

                    @if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="alert alert-danger small">
                            <span asp-validation-summary="All"></span>
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="AccountId" class="form-label-pro">Deposit to account</label>
                        <select asp-for="AccountId" class="form-select form-control-pro">
                            <option value="">-- Select account --</option>
                            @foreach (var a in accounts.Where(x => x.Status == "Active"))
                            {
                                <option value="@a.AccountId">
                                    @a.AccountType - @a.AccountNumber (Balance: INR @a.Balance.ToString("N2"))
                                </option>
                            }
                        </select>
                        <span asp-validation-for="AccountId" class="field-validation-error"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Amount" class="form-label-pro">Amount (INR)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">INR</span>
                            <input asp-for="Amount" type="number" step="0.01" min="1"
                                   class="form-control form-control-pro" placeholder="500.00" />
                        </div>
                        <div class="form-help">Enter amount between INR 1 and 10,000,000.</div>
                        <span asp-validation-for="Amount" class="field-validation-error"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label-pro">Description (optional)</label>
                        <input asp-for="Description" class="form-control form-control-pro"
                               placeholder="e.g. Salary, Cash deposit" maxlength="500" />
                    </div>

                    <button type="submit" class="btn btn-primary-pro">
                        <i class="bi bi-cash-coin me-1"></i>Deposit funds
                    </button>
                    <a asp-controller="Accounts" asp-action="Index" class="btn btn-outline-pro">Cancel</a>
                </form>
            }
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card-pro">
            <h6 class="fw-bold"><i class="bi bi-info-circle me-1 text-primary"></i>About deposits</h6>
            <ul class="small text-muted ps-3 mb-0">
                <li class="mb-2">Deposits credit immediately to your account.</li>
                <li class="mb-2">All transactions are logged for security.</li>
                <li class="mb-2">You will receive a notification on success.</li>
                <li class="mb-2">Reference number is generated for every deposit.</li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
