@{
    var isAuthPage   = ViewContext.RouteData.Values["controller"]?.ToString() == "Auth";
    var isLoggedIn   = Context.Request.Cookies.ContainsKey("SmartBankToken");
    var userName     = Context.Request.Cookies["UserName"];
    var userRole     = Context.Request.Cookies["UserRole"] ?? "Customer";
    var currentCtrl  = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAct   = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string ActiveIf(string ctrl, string? action = null)
        => currentCtrl.Equals(ctrl, StringComparison.OrdinalIgnoreCase)
           && (action is null || currentAct.Equals(action, StringComparison.OrdinalIgnoreCase))
                ? "active" : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartBank</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/smartbank.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@(isAuthPage ? "auth-body" : "app-body")">
    @if (isAuthPage || !isLoggedIn)
    {
        <main>
            @RenderBody()
        </main>
    }
    else
    {
        <div class="app-shell">
            <aside class="app-sidebar" id="appSidebar">
                <div class="sidebar-brand">
                    <div class="brand-mark"><i class="bi bi-bank2"></i></div>
                    <div class="brand-text">
                        <span class="brand-name">SmartBank</span>
                        <span class="brand-tag">Digital Banking</span>
                    </div>
                </div>

                <nav class="sidebar-nav">
                    <div class="nav-section-label">Main</div>
                    <a class="nav-link @ActiveIf("Dashboard")" asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-grid-1x2"></i><span>Dashboard</span>
                    </a>
                    <a class="nav-link @ActiveIf("Profile")" asp-controller="Profile" asp-action="Index">
                        <i class="bi bi-person-circle"></i><span>My Profile</span>
                    </a>

                    <div class="nav-section-label">Banking</div>
                    <a class="nav-link @ActiveIf("Accounts")" asp-controller="Accounts" asp-action="Index">
                        <i class="bi bi-wallet2"></i><span>My Accounts</span>
                    </a>
                    <a class="nav-link @ActiveIf("Transactions", "Deposit")" asp-controller="Transactions" asp-action="Deposit">
                        <i class="bi bi-cash-coin"></i><span>Deposit</span>
                    </a>
                    <a class="nav-link @ActiveIf("Transactions", "Withdraw")" asp-controller="Transactions" asp-action="Withdraw">
                        <i class="bi bi-arrow-down-circle"></i><span>Withdraw</span>
                    </a>
                    <a class="nav-link @ActiveIf("Transactions", "Transfer")" asp-controller="Transactions" asp-action="Transfer">
                        <i class="bi bi-arrow-left-right"></i><span>Transfer</span>
                    </a>
                    <a class="nav-link @ActiveIf("Transactions", "History")" asp-controller="Transactions" asp-action="History">
                        <i class="bi bi-clock-history"></i><span>Statement</span>
                    </a>

                    <div class="nav-section-label">Services</div>
                    <a class="nav-link @ActiveIf("Loans")" asp-controller="Loans" asp-action="Index">
                        <i class="bi bi-bank"></i><span>Loans</span>
                    </a>
                    <a class="nav-link @ActiveIf("Support")" asp-controller="Support" asp-action="Index">
                        <i class="bi bi-headset"></i><span>Support</span>
                    </a>
                    <a class="nav-link @ActiveIf("Notifications")" asp-controller="Notifications" asp-action="Index">
                        <i class="bi bi-bell"></i><span>Notifications</span>
                    </a>

                    @if (userRole == "Admin" || userRole == "Manager")
                    {
                        <div class="nav-section-label">Administration</div>
                        <a class="nav-link @ActiveIf("Admin", "Index")" asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-speedometer2"></i><span>Admin Dashboard</span>
                        </a>
                        <a class="nav-link @ActiveIf("Admin", "Users")" asp-controller="Admin" asp-action="Users">
                            <i class="bi bi-people"></i><span>Users</span>
                        </a>
                        <a class="nav-link @ActiveIf("Admin", "Loans")" asp-controller="Admin" asp-action="Loans">
                            <i class="bi bi-file-earmark-check"></i><span>Loan Reviews</span>
                        </a>
                        <a class="nav-link @ActiveIf("Admin", "Reports")" asp-controller="Admin" asp-action="Reports">
                            <i class="bi bi-bar-chart"></i><span>Reports</span>
                        </a>
                    }
                </nav>

                <div class="sidebar-footer">
                    <a class="nav-link" asp-controller="Auth" asp-action="Logout">
                        <i class="bi bi-box-arrow-right"></i><span>Sign out</span>
                    </a>
                </div>
            </aside>

            <div class="app-main">
                <header class="app-topbar">
                    <button class="btn btn-link sidebar-toggle d-lg-none" id="sidebarToggle" aria-label="Toggle navigation">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="topbar-title">
                        <span class="page-title">@(ViewData["Title"] ?? "")</span>
                    </div>
                    <div class="topbar-actions ms-auto">
                        <a class="topbar-icon" asp-controller="Notifications" asp-action="Index" title="Notifications">
                            <i class="bi bi-bell"></i>
                            @if (ViewBag.UnreadCount != null && (int)ViewBag.UnreadCount > 0)
                            {
                                <span class="topbar-badge">@ViewBag.UnreadCount</span>
                            }
                        </a>
                        <div class="dropdown">
                            <button class="topbar-user dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="avatar">@((userName ?? "U").Substring(0, 1).ToUpper())</span>
                                <span class="d-none d-md-inline ms-2">@(userName ?? "User")</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index"><i class="bi bi-person me-2"></i>Profile</a></li>
                                <li><a class="dropdown-item" asp-controller="Accounts" asp-action="Index"><i class="bi bi-wallet me-2"></i>Accounts</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Sign out</a></li>
                            </ul>
                        </div>
                    </div>
                </header>

                <main class="app-content">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @RenderBody()
                </main>

                <footer class="app-footer">
                    <small class="text-muted">&copy; @DateTime.Now.Year SmartBank Digital Banking System &middot; Built with ASP.NET Core 9</small>
                </footer>
            </div>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function() {
            var toggle = document.getElementById('sidebarToggle');
            var sidebar = document.getElementById('appSidebar');
            if (toggle && sidebar) {
                toggle.addEventListener('click', function() {
                    sidebar.classList.toggle('show');
                });
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
