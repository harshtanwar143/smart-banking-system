@model SmartBank.Models.DTOs.Profile.ProfileDto
@{
    ViewData["Title"] = "My Profile";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>My Profile</h1>
        <p>Manage your personal information and contact details.</p>
    </div>
    <a asp-action="Edit" class="btn btn-primary-pro">
        <i class="bi bi-pencil me-1"></i>Edit profile
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card-pro text-center">
            <div class="d-flex justify-content-center mb-3">
                <div class="avatar" style="width: 80px; height: 80px; font-size: 2rem;">
                    @(Model.Name.Length > 0 ? Model.Name.Substring(0,1).ToUpper() : "U")
                </div>
            </div>
            <h5 class="fw-bold mb-1">@Model.Name</h5>
            <p class="text-muted small mb-3">@Model.Email</p>
            <span class="badge-pro success">
                <i class="bi bi-shield-check"></i>Verified Customer
            </span>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card-pro">
            <div class="card-pro-header">
                <h5>Personal Information</h5>
            </div>

            <dl class="row mb-0">
                <dt class="col-sm-4 text-muted small fw-normal py-2 border-bottom border-light">Full name</dt>
                <dd class="col-sm-8 py-2 border-bottom border-light fw-semibold">@Model.Name</dd>

                <dt class="col-sm-4 text-muted small fw-normal py-2 border-bottom border-light">Email</dt>
                <dd class="col-sm-8 py-2 border-bottom border-light fw-semibold">@Model.Email</dd>

                <dt class="col-sm-4 text-muted small fw-normal py-2 border-bottom border-light">Phone</dt>
                <dd class="col-sm-8 py-2 border-bottom border-light fw-semibold">
                    @(string.IsNullOrEmpty(Model.Phone) ? "Not provided" : Model.Phone)
                </dd>

                <dt class="col-sm-4 text-muted small fw-normal py-2 border-bottom border-light">Address</dt>
                <dd class="col-sm-8 py-2 border-bottom border-light fw-semibold">
                    @(string.IsNullOrEmpty(Model.Address) ? "Not provided" : Model.Address)
                </dd>

                <dt class="col-sm-4 text-muted small fw-normal py-2">Date of Birth</dt>
                <dd class="col-sm-8 py-2 fw-semibold">
                    @(string.IsNullOrEmpty(Model.DateOfBirth) ? "Not provided" : Model.DateOfBirth)
                </dd>
            </dl>
        </div>
    </div>
</div>
