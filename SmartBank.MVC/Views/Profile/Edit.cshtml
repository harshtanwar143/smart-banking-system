@model SmartBank.Models.DTOs.Profile.UpdateProfileDto
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="page-header">
    <h1>Edit Profile</h1>
    <p>Update your contact details. Email cannot be changed.</p>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card-pro">
            <form asp-action="Edit" method="post" novalidate>
                @Html.AntiForgeryToken()

                @if (ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert alert-danger small">
                        <span asp-validation-summary="All"></span>
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label-pro">Email <span class="text-muted small">(cannot be changed)</span></label>
                    <input class="form-control form-control-pro bg-light" value="@ViewBag.Email" disabled />
                </div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label-pro">Full name</label>
                    <input asp-for="Name" class="form-control form-control-pro" placeholder="First Last" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="form-label-pro">Phone (10 digits)</label>
                    <input asp-for="Phone" class="form-control form-control-pro"
                           placeholder="9876543210" maxlength="10" pattern="\d{10}" />
                    <span asp-validation-for="Phone" class="field-validation-error"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Address" class="form-label-pro">Address</label>
                    <textarea asp-for="Address" class="form-control form-control-pro" rows="3"
                              placeholder="123, Street Name, City, PIN"></textarea>
                    <span asp-validation-for="Address" class="field-validation-error"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary-pro">
                        <i class="bi bi-check-lg me-1"></i>Save changes
                    </button>
                    <a asp-action="Index" class="btn btn-outline-pro">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
